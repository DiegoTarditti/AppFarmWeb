# Copiá este archivo a .env en cada máquina y ajustá según lo que tengas libre.
# El .env real está en .gitignore así que no se versiona.
# Los defaults del docker-compose.yml (entre llaves) se aplican si no definís el .env.

# Puerto host para la DB farmacia (default 5433)
FARMACIA_DB_PORT=5433

# Puerto host para la DB simulada de ObServer (default 5435, en casa suele ser 5434)
OBSERVER_DB_PORT=5435

# Puerto host para la app web Flask (default 5000)
WEB_PORT=5000

# ──────────────────────────────────────────────────────────────────────────
# Conexión a la DB real de ObServer (SQL Server 2014). Solo funciona desde
# máquinas en la misma LAN de la farmacia (o vía Tailscale). Si dejás
# OBSERVER_HOST vacío, la app arranca igual y el sync queda deshabilitado.
# ──────────────────────────────────────────────────────────────────────────
# DB externa de Render, para replicar obs_* desde local → cloud.
# Copiala de: Render dashboard → tu Postgres → Connections → External Database URL.
# Si queda vacío, el botón "Push a Render" del panel admin no funciona.
RENDER_DATABASE_URL=

OBSERVER_HOST=192.168.1.137
OBSERVER_PORT=54572
OBSERVER_USER=usuarioDW
OBSERVER_PASS=UDW_FarmaciaFS2025
OBSERVER_DB=ObServerGestion
OBSERVER_TDSVER=7.0
OBSERVER_ID_FARMACIA=10525
