# AppNúcleo — variables. NO commitear el .env real (URLs con credenciales).

# Registro de farmacias del grupo (JSON). Usar rol READ-ONLY por farmacia.
NUCLEO_FARMACIAS=[{"slug":"badia","nombre":"Badia","url":"postgresql://USER:PASS@HOST/DB"},{"slug":"pieri","nombre":"Pieri","url":"postgresql://USER:PASS@HOST/DB"}]

# Secret de sesión del Núcleo.
NUCLEO_SECRET_KEY=cambiar-por-uno-largo-y-unico

# Puerto local (default 5001).
NUCLEO_PORT=5001
